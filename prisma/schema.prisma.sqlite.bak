generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================
// חנויות / פלטפורמות אפילייט
// ============================================
model Store {
  id              String   @id @default(cuid())
  name            String   @unique
  platform        Platform
  logoUrl         String?
  baseUrl         String
  affiliateConfig Json     // { appKey, secret, trackingId, etc. }
  trustScore      Int      @default(70) // 0-100
  commissionRate  Float    @default(0.05) // 5%
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  products Product[]

  @@index([platform])
}

enum Platform {
  ALIEXPRESS
  TEMU
  IHERB
  AMAZON
}

// ============================================
// קטגוריות
// ============================================
model Category {
  id          String   @id @default(cuid())
  nameHe      String
  nameEn      String
  slug        String   @unique
  parentId    String?
  parent      Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryTree")
  demandScore Int      @default(50) // 0-100 ביקוש בישראל
  icon        String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  products Product[]

  @@index([parentId])
}

// ============================================
// מוצרים / דילים
// ============================================
model Product {
  id               String        @id @default(cuid())
  externalId       String        // מזהה מהחנות
  storeId          String
  store            Store         @relation(fields: [storeId], references: [id])
  categoryId       String?
  category         Category?     @relation(fields: [categoryId], references: [id])

  // מידע בסיסי
  titleEn          String
  titleHe          String?
  descriptionEn    String?
  descriptionHe    String?
  imageUrl         String?
  imageUrls        String?       // JSON array of URLs
  productUrl       String
  affiliateUrl     String?

  // מחירים
  priceOriginal    Float
  priceCurrent     Float
  currency         String        @default("USD")
  shippingCost     Float         @default(0)
  shippingFree     Boolean       @default(false)
  priceILS         Float?        // מחיר סופי בשקלים
  priceWithVat     Float?        // מחיר כולל מע"מ אם רלוונטי
  vatApplies       Boolean       @default(false)

  // קופון
  couponCode       String?
  couponValue      Float?
  couponType       CouponType?

  // דירוג
  rating           Float?
  reviewCount      Int           @default(0)

  // ציון ומצב
  score            Int           @default(0) // 0-100
  status           ProductStatus @default(PENDING)
  isPublished      Boolean       @default(false)
  publishedAt      DateTime?
  expiresAt        DateTime?

  // מטא
  tags             String?       // JSON array of tags
  targetAudience   String?       // JSON array: ["women", "home", "tech"]
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  posts       Post[]
  clicks      Click[]
  conversions Conversion[]

  @@unique([externalId, storeId])
  @@index([storeId])
  @@index([categoryId])
  @@index([score])
  @@index([status])
  @@index([isPublished])
  @@index([createdAt])
}

enum ProductStatus {
  PENDING     // ממתין לבדיקה
  APPROVED    // אושר
  PUBLISHED   // פורסם
  REJECTED    // נדחה
  EXPIRED     // פג תוקף
}

enum CouponType {
  PERCENT
  FIXED
}

// ============================================
// פוסטים (אתר + טלגרם)
// ============================================
model Post {
  id                String      @id @default(cuid())
  productId         String
  product           Product     @relation(fields: [productId], references: [id])
  channel           Channel
  variant           PostVariant

  // תוכן
  titleHe           String
  bodyHe            String
  ctaHe             String?
  prosHe            String?     // יתרונות
  consHe            String?     // חסרון אחד אמיתי לאמון

  // מטא
  slug              String?     @unique // לאתר
  metaDescription   String?
  telegramMessageId String?     // מזהה הודעה בטלגרם
  isPublished       Boolean     @default(false)
  publishedAt       DateTime?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  clicks Click[]

  @@index([productId])
  @@index([channel])
  @@index([publishedAt])
}

enum Channel {
  WEB
  TELEGRAM
}

enum PostVariant {
  SEO_LONG     // עמוד מלא באתר עם SEO
  SHORT_FIRE   // פוסט קצר "פצצה" לטלגרם
  SOCIAL_PROOF // גרסה מבוססת ביקורות
}

// ============================================
// מעקב קליקים
// ============================================
model Click {
  id          String   @id @default(cuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  postId      String?
  post        Post?    @relation(fields: [postId], references: [id])

  // מקור
  channel     Channel
  source      String?  // utm_source
  medium      String?  // utm_medium
  campaign    String?  // utm_campaign
  subId       String?  // sub_id לאפילייט

  // מידע נוסף
  ipHash      String?
  userAgent   String?
  referer     String?
  country     String?  @default("IL")

  createdAt   DateTime @default(now())

  conversion  Conversion?

  @@index([productId])
  @@index([postId])
  @@index([channel])
  @@index([createdAt])
  @@index([subId])
}

// ============================================
// המרות / מכירות
// ============================================
model Conversion {
  id           String           @id @default(cuid())
  clickId      String?          @unique
  click        Click?           @relation(fields: [clickId], references: [id])
  productId    String
  product      Product          @relation(fields: [productId], references: [id])
  storeId      String

  // נתוני מכירה
  orderId      String?
  orderAmount  Float
  commission   Float
  currency     String           @default("USD")
  status       ConversionStatus @default(PENDING)

  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([productId])
  @@index([storeId])
  @@index([status])
  @@index([createdAt])
}

enum ConversionStatus {
  PENDING
  APPROVED
  REJECTED
}

// ============================================
// דוחות יומיים
// ============================================
model DailyReport {
  id              String   @id @default(cuid())
  date            DateTime @unique
  totalClicks     Int      @default(0)
  totalConversions Int     @default(0)
  totalRevenue    Float    @default(0)
  totalCommission Float    @default(0)
  epc             Float    @default(0) // Earnings Per Click
  conversionRate  Float    @default(0)

  // פירוט
  topProducts     Json?    // [{ productId, clicks, conversions, revenue }]
  topCategories   Json?    // [{ categoryId, clicks, conversions }]
  channelBreakdown Json?   // { web: { clicks, conv }, telegram: { clicks, conv } }
  storeBreakdown  Json?    // { aliexpress: {...}, temu: {...}, iherb: {...} }

  // תובנות AI
  insightsHe      String?
  recommendations String?

  createdAt       DateTime @default(now())
}

// ============================================
// הגדרות מערכת
// ============================================
model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt
}
